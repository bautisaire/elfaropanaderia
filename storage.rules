rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      // Solo admins pueden subir/borrar imágenes para no saturar el servidor con basura.
      allow write: if request.auth != null && (
        request.auth.token.email == "sairebautista@gmail.com" || 
        request.auth.token.email == "mariacoronel160478@gmail.com" ||
        request.auth.token.email == "litijunior@hotmail.com.ar"
      );
    }
  }
}
