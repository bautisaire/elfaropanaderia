rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para verificar si es admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "sairebautista@gmail.com" || 
        request.auth.token.email == "mariacoronel160478@gmail.com" ||
        request.auth.token.email == "litijunior@hotmail.com.ar" 
      );
    }

    match /products/{productId} {
      allow read: if true;
      
      // Solo admins pueden crear o borrar productos
      allow create, delete: if isAdmin();
      
      // Admins pueden editar todo. 
      // Clientes SOLO pueden editar stock (para que funcione el descuento).
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stockQuantity', 'variants', 'stock'])
      );
    }

    // Categorías
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pedidos
    match /orders/{orderId} {
      allow create, read: if true;
      allow update: if isAdmin() || (
        request.auth != null &&
        resource.data.assignedRider == request.auth.token.email
      );
      allow delete: if isAdmin();
    }

    // Hero Slides
    match /hero_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configuración antigua (Estado de la tienda)
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- NUEVO: Configuración General (Compra Mínima y Contador) ---
    match /config/store_settings {
        allow read: if true;
        allow write: if isAdmin();
    }

    // Regla crucial para que los clientes puedan generar IDs secuenciales
    match /config/order_counter {
        allow read: if true;
        // Permitimos update para que funcione el checkout (incremento)
        allow update: if true; 
        allow create: if isAdmin();
    }
    
    // Fallback para otros docs en config
    match /config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Movimientos de Stock
    match /stock_movements/{movementId} {
      allow create: if true; 
      allow read, update, delete: if isAdmin();
    }

    // Estadísticas
    match /stats/{document=**} {
      allow read, write: if true;
    }

    // Extras/Bonos de Repartidores
    match /rider_extras/{extraId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == resource.data.riderEmail) || true;
      allow write: if isAdmin();
    }

    // --- NUEVOS MÓDULOS DE USUARIOS ---
    match /admin_roles/{roleId} {
      allow read: if request.auth != null && (request.auth.token.email == roleId || request.auth.token.email == "sairebautista@gmail.com");
      allow write: if request.auth != null && request.auth.token.email == "sairebautista@gmail.com";
    }

    match /users/{userId} {
      // Un usuario puede leer y escribir SOLO su propio documento
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Un admin puede leer toda la lista de usuarios para el panel "UsersManager"
      allow read: if isAdmin();
    }
  } 
}
