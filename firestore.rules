rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para verificar si es admin
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email != null && (
        request.auth.token.email.lower() == "sairebautista@gmail.com" || 
        request.auth.token.email.lower() == "mariacoronel160478@gmail.com" ||
        request.auth.token.email.lower() == "litijunior@hotmail.com.ar" ||
        request.auth.token.email.lower() == "juampi.sme@outlook.com.ar"
      );
    }

    function isAdmin() {
      return isSuperAdmin() || (
        request.auth != null && request.auth.token.email != null &&
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.token.email.lower())) &&
        get(/databases/$(database)/documents/admin_roles/$(request.auth.token.email.lower())).data.get('is_rider', false) == false
      );
    }

    function isRider() {
      return request.auth != null && request.auth.token.email != null &&
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.token.email.lower())) &&
        get(/databases/$(database)/documents/admin_roles/$(request.auth.token.email.lower())).data.get('is_rider', false) == true;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stockQuantity', 'variants', 'stock'])
      );

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pedidos (Seguridad Fuerte)
    match /orders/{orderId} {
      allow get: if true; // Permitir que un cliente lea su propio pedido si conoce el ID exacto
      allow create: if isAdmin(); // El backend procesa pedidos nuevos o Admins locales
      allow list: if isAdmin() || isRider(); // Solo admins y riders pueden listar todos los pedidos
      allow update: if isAdmin() || (
        request.auth != null &&
        resource.data.assignedRider == request.auth.token.email
      );
      allow delete: if isAdmin();
    }

    match /hero_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /raffles/{raffleId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /participants/{participantId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/store_settings {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /config/order_counter {
        allow read: if true;
        allow update: if true; // Frontend incrementa
        allow create: if isAdmin();
    }
    
    match /config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stock_movements/{movementId} {
      allow create: if true; 
      allow read, update, delete: if isAdmin();
    }

    match /stats/{document=**} {
      allow read, write: if isAdmin();
    }

    match /stock_alerts/{alertId} {
      allow read: if isAdmin();
      allow create, update, delete: if true;
    }

    match /rider_extras/{extraId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == resource.data.riderEmail);
      allow write: if isAdmin();
    }

    match /raw_materials/{document=**} {
      allow read, write: if isAdmin();
    }
    match /cif_items/{document=**} {
      allow read, write: if isAdmin();
    }
    match /expenses/{document=**} {
      allow read, write: if isAdmin();
    }
    match /time_entries/{document=**} {
      allow read, write: if isAdmin();
    }
    match /employees/{document=**} {
      allow read, write: if isAdmin();
    }
    match /lista_espera/{document=**} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    match /admin_roles/{roleId} {
      allow read: if request.auth != null && (request.auth.token.email != null && request.auth.token.email.lower() == roleId || isSuperAdmin());
      allow write: if isSuperAdmin();
    }

    match /{path=**}/reviews/{reviewId} {
      allow read: if true;
    }

    match /users/{userId} {
      // Un usuario solo puede leer/escribir sus propios datos, admins pueden leer todo
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  } 
}
